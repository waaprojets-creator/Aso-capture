<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    tools:context=".ui.CaptureActivity">

    <!-- Preview caméra plein écran -->
    <androidx.camera.view.PreviewView
        android:id="@+id/preview_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- HUD top : indicateurs qualité -->
    <LinearLayout
        android:id="@+id/hud_top"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#80000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/indicator_imu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="IMU: --"
            android:textColor="@android:color/white" />

        <TextView
            android:id="@+id/indicator_gnss"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="GNSS: --"
            android:textColor="@android:color/white" />

        <TextView
            android:id="@+id/indicator_baro"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="BARO: --"
            android:textColor="@android:color/white" />

        <TextView
            android:id="@+id/indicator_duration"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="00:00"
            android:textColor="@android:color/white"
            android:gravity="end" />
    </LinearLayout>

    <!-- HUD bottom : actions principales -->
    <LinearLayout
        android:id="@+id/hud_bottom"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#80000000"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btn_calibrate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/calibrate" />

        <Button
            android:id="@+id/btn_mark_gcp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/mark_gcp"
            android:layout_marginStart="8dp" />

        <Button
            android:id="@+id/btn_critical_burst"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/critical_burst"
            android:layout_marginStart="8dp" />

        <Button
            android:id="@+id/btn_stop_scan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/stop_scan"
            android:layout_marginStart="8dp"
            android:backgroundTint="@color/red_critical" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
