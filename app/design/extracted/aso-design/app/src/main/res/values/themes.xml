<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.AsoCapture" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/aso_text_primary</item>
        <item name="colorPrimaryVariant">@color/aso_text_secondary</item>
        <item name="colorOnPrimary">@color/aso_bg_base</item>
        <item name="colorSecondary">@color/aso_accent</item>
        <item name="colorSecondaryVariant">@color/aso_accent_dim</item>
        <item name="colorOnSecondary">@color/aso_text_on_accent</item>
        <item name="android:colorBackground">@color/aso_bg_base</item>
        <item name="colorSurface">@color/aso_bg_surface</item>
        <item name="colorOnBackground">@color/aso_text_primary</item>
        <item name="colorOnSurface">@color/aso_text_primary</item>
        <item name="colorError">@color/aso_status_crit</item>
        <item name="android:statusBarColor">@color/aso_bg_base</item>
        <item name="android:navigationBarColor">@color/aso_bg_base</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>

    <!-- Styles typographiques -->
    <style name="AsoText.Display" parent="">
        <item name="android:fontFamily">sans-serif-light</item>
        <item name="android:textSize">@dimen/aso_text_display</item>
        <item name="android:letterSpacing">-0.05</item>
        <item name="android:textColor">@color/aso_text_primary</item>
    </style>

    <style name="AsoText.Title" parent="">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">@dimen/aso_text_xl</item>
        <item name="android:letterSpacing">-0.02</item>
        <item name="android:textColor">@color/aso_text_primary</item>
    </style>

    <style name="AsoText.Body" parent="">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">@dimen/aso_text_base</item>
        <item name="android:textColor">@color/aso_text_primary</item>
    </style>

    <style name="AsoText.Mono" parent="">
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">@dimen/aso_text_sm</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:textColor">@color/aso_text_secondary</item>
    </style>

    <style name="AsoText.MonoLabel" parent="AsoText.Mono">
        <item name="android:textSize">@dimen/aso_text_xs</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/aso_text_tertiary</item>
    </style>

    <!-- Boutons -->
    <style name="AsoButton.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/aso_text_primary</item>
        <item name="android:textColor">@color/aso_bg_base</item>
        <item name="cornerRadius">@dimen/aso_radius_lg</item>
        <item name="android:minHeight">@dimen/aso_touch_min</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="AsoButton.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/aso_border_default</item>
        <item name="android:textColor">@color/aso_text_primary</item>
        <item name="cornerRadius">@dimen/aso_radius_md</item>
        <item name="android:minHeight">@dimen/aso_touch_min</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="AsoButton.Critical" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/aso_status_crit</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">@dimen/aso_radius_round</item>
        <item name="android:textAllCaps">false</item>
    </style>

</resources>
